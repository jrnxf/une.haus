{
  "name": "une.haus",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter web dev",
    "build": "bun run --filter web build",
    "start": "bun run --filter web start",
    "preflight": "bun run --filter web preflight",
    "lint": "oxlint",
    "format": "oxfmt --write",
    "check": "oxlint --fix && oxfmt --write",
    "docs:dev": "bun run --filter docs dev",
    "docs:build": "bun run --filter docs build"
  },
  "devDependencies": {
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0"
  }
}
