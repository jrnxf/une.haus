# Web app environment. Copy to apps/web/.env and fill in real values.
# Loaded by `bun dev` (local) and by the app container in docker-compose.yml.

# --- Database -----------------------------------------------------------------
# Local dev against the bundled docker postgres (5432 on localhost).
# Inside docker compose, DATABASE_URL is overridden to point at the in-network
# `postgres` service — the value here only matters for `bun dev`.
DATABASE_URL=postgres://unehaus:unehaus_dev_password@localhost:5432/unehaus

# --- Cloudflare Images --------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGES_EDITOR_API_TOKEN=

# --- Google Maps --------------------------------------------------------------
GOOGLE_API_KEY=

# --- Mux (video) --------------------------------------------------------------
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# --- Resend (email) -----------------------------------------------------------
RESEND_API_KEY=

# --- Sessions -----------------------------------------------------------------
SESSION_SECRET=

# --- Sentry (optional) --------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
VITE_SENTRY_DSN=

# --- Misc (optional) ----------------------------------------------------------
# VITE_ENVIRONMENT=production    # defaults to "development"
# LOG_SQL=true                   # defaults to false
