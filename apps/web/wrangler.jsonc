{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "unehaus-web",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": [
      // RIU rotation: Mondays 00:00 UTC
      "0 0 * * 1",
      // Hourly digests + game-start reminders
      "0 * * * *"
    ]
  }
  // env.production.routes added in C9 once cf.une.haus zone is wired up
}
