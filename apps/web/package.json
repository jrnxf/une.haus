{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --host",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' vite build && cp instrument.server.mjs .output/server",
    "bundle:info": "bun run src/scripts/bundle/info.ts",
    "bundle:analyze": "bunx vite-bundle-visualizer",
    "start": "bun --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "db:seed": "bun src/db/scripts/wipe.ts && bunx drizzle-kit push && bun src/db/scripts/seed.ts",
    "db:migrate": "bunx drizzle-kit push",
    "db:reset-dev": "bun run src/scripts/reset-dev-db.ts",
    "db:clean-notifications": "bun run src/scripts/clean-orphaned-notifications.ts",
    "email:dev": "npx react-email dev",
    "typecheck": "tsgo --noEmit",
    "test:unit": "bun test unit.test",
    "test:integration": "bun run src/scripts/run-integration-tests.ts",
    "clean": "bunx knip --include files,dependencies,exports,types --fix --allow-remove-files"
  },
